rules_version = '2';

// Iconundrum — Firestore security rules.
// Model: ONE document per completed game in /games. Public read (leaderboards),
// validated create-only writes, no updates or deletes ever.
// Paste into Firebase console → Firestore → Rules, then Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    match /games/{gameId} {
      allow read: if true;
      allow create: if validGame();
      allow update, delete: if false;

      function validGame() {
        let d = request.resource.data;
        return d.keys().hasOnly(['ck', 'mode', 'pack', 'seed', 'v', 'player', 'score', 'rounds', 'created'])
          && d.keys().hasAll(['ck', 'mode', 'pack', 'seed', 'v', 'player', 'score', 'rounds', 'created'])
          && d.ck is string && d.ck.size() <= 64
          && d.mode in ['icon', 'value', 'hl']
          && d.pack == 'items'
          && d.seed is string && d.seed.size() >= 1 && d.seed.size() <= 16
          && d.v is int && d.v >= 1 && d.v <= 1000
          && d.player is string && d.player.size() >= 1 && d.player.size() <= 20
          && d.score is int && d.score >= 0 && d.score <= 1000000
          && d.rounds is list && d.rounds.size() <= 60
          && d.created == request.time;
      }
    }

    // Multiplayer lobbies — one doc per lobby, keyed by game code (= seed).
    // Public read (roster), validated create, bounded updates (joins +
    // host launch). cfg and host are immutable after create; no deletes
    // (stale lobbies are inert — links to them fall back to async mode).
    match /lobbies/{code} {
      allow read: if true;
      allow create: if validLobbyCreate();
      allow update: if validLobbyUpdate();
      allow delete: if false;

      function validLobbyCreate() {
        let d = request.resource.data;
        return d.keys().hasOnly(['cfg', 'host', 'players', 'state', 'launchAt', 'round', 'roundAt', 'scores', 'created'])
          && d.keys().hasAll(['cfg', 'host', 'players', 'state', 'launchAt', 'round', 'roundAt', 'scores', 'created'])
          && code.size() >= 1 && code.size() <= 16
          && d.cfg is map
          && d.host is string && d.host.size() >= 1 && d.host.size() <= 20
          && d.players is list && d.players.size() >= 1 && d.players.size() <= 40
          && d.state == 'open'
          && d.launchAt == null
          && d.round == 0
          && d.roundAt == null
          && d.scores is map && d.scores.size() == 0
          && d.created == request.time;
      }

      // Joins (players append, only while open), host launch, host round
      // advances, and per-round score reports. cfg/host immutable.
      function validLobbyUpdate() {
        let d = request.resource.data;
        return d.keys().hasOnly(['cfg', 'host', 'players', 'state', 'launchAt', 'round', 'roundAt', 'scores', 'created'])
          && d.cfg == resource.data.cfg
          && d.host == resource.data.host
          && d.players is list && d.players.size() <= 40
          && (resource.data.state == 'open' || d.players == resource.data.players)
          && d.state in ['open', 'launching']
          && (d.launchAt == null || d.launchAt is number)
          && d.round is int && d.round >= 0 && d.round <= 60
          && (d.roundAt == null || d.roundAt is number)
          && d.scores is map && d.scores.size() <= 40;
      }
    }

    // Everything else stays locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
